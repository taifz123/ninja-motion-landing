# Stripe Payment Link (used in the frontend buy buttons)
VITE_STRIPE_PAYMENT_LINK=https://buy.stripe.com/your-link-here

# Stripe (server-side — for webhook PDF delivery)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (email delivery)
RESEND_API_KEY=re_...
FROM_EMAIL=Ninja Motion Therapies <hello@ninjamotiontherapies.com.au>

# PDF file URL (publicly accessible — attached to purchase email)
PDF_URL=https://your-domain.com/7-Day-Movement-Reset.pdf
